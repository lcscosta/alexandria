FROM python:3.12-slim

# Install system deps
RUN apt-get update && apt-get install -y \
    nodejs npm \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ---- Backend setup ----
COPY ./backend /app/backend
WORKDIR /app/backend
RUN pip install .

# ---- Frontend setup ----
WORKDIR /app/frontend
COPY ./frontend/package*.json ./
RUN npm install
COPY ./frontend .

# Back to root
WORKDIR /app

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/backend

# Expose ports
EXPOSE 8000 3000

# Run BOTH services (no supervisor, just shell)
CMD sh -c "\
cd /app/backend/alexandria_backend && uvicorn main:app --host 0.0.0.0 --port 8000 --reload & \
cd /app/frontend && npm run dev \
"